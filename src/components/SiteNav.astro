<nav class="site-nav">
  <div class="nav-content">
    <a href="/about">About</a>
    <a href="/archive">Archive</a>
  </div>
</nav>

<style>
  .site-nav {
    background: white;
    padding: 0;
    text-align: left;
    margin-top: -1px; /* Remove any gap between header and nav */
    position: relative;
    z-index: 2;
  }

  .nav-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    padding-bottom: 3.5rem; /* Some bottom padding */
  }

  .site-nav a {
    font-family: 'Sentient', 'Georgia', serif;
    font-size: 2.5rem;
    margin: -0.95rem 1.5rem 0 1.5rem;
    font-weight: 400;
    color: black;
    text-decoration: none;
    position: relative;
    z-index: 3;
    display: inline-block;
    transform: rotate(180deg); /* Flip text right-side up so it's readable */
    /* Remove padding and keep only stabilizing properties */
    transform-style: preserve-3d;
    backface-visibility: hidden;
  }
  
  /* Inspired (heavily) by https://codepen.io/geoffgraham/pen/yLzvXyL */
  .site-nav a::before {
    background: #ff9a3c;
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.25s ease-in-out;
    z-index: -1;
    will-change: transform;
  }
  
  .site-nav a:hover {
    /* Prevent text movement on hover */
    transform: rotate(180deg) translateZ(0);
  }
  
  .site-nav a:hover::before {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* Add responsive styling for smaller screens */
  @media (max-width: 768px) {
    .site-nav a {
      font-size: 1.8rem;
      margin: -0.65rem 1rem 0 1rem;
      /* Remove padding */
    }
    
    .nav-content {
      padding-bottom: 2.5rem;
    }
  }
</style>
