---
---
<header class="site-header">
  <div class="header-content">
    <h1 class="logo">
      <a href="/" aria-label="Twistinside home">Twistinside</a>
    </h1>
  </div>
</header>

<style>
  .site-header {
    background: black;
    color: white;
    padding: 10rem 2rem 0;
    position: relative;
    height: 16rem;
    z-index: 1;
  }

  .header-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    height: 100%;
  }

  .logo {
    font-family: 'Nightingale', Georgia, serif;
    font-size: clamp(3rem, 15vw, 8.5rem);
    font-weight: 300;
    margin: 0;
    padding: 0;
    line-height: 1;
    position: absolute;
    bottom: -0.25em;
    left: 0;
    right: 0;
    pointer-events: none;
  }

  .logo a {
    color: white;
    text-decoration: none;
    pointer-events: auto;
    display: inline-block;
  }
  
  .logo a:hover {
    text-decoration: none;
  }

  .logo.font-loading {
    font-family: Georgia, serif;
  }

  @media (max-width: 768px) {
    .site-header {
      padding: 8rem 2rem 0;
      height: 12rem;
    }
  }
</style>
