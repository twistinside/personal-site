---
import Header from '../components/Header.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
const { title = "Twistinside" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="Twistinside RSS Feed" href="/rss.xml" />

    <!-- Preload critical assets -->
    <link rel="preload" href="/fonts/nightingale.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/sentient-light.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/ia-mono-regular.woff2" as="font" type="font/woff2" crossorigin />
    
    <!-- Prevent FOUC -->
    <style>
      html {
        visibility: hidden;
      }
      
      /* Add critical font styles to prevent FOUC */
      @font-face {
        font-family: 'Nightingale';
        src: url('/fonts/nightingale.woff2') format('woff2');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
      
      /* Pre-define logo styles to prevent size jump */
      .logo {
        font-family: 'Nightingale', Georgia, serif;
        font-size: 8.5rem;
        font-weight: 300;
      }
      
      @media (max-width: 768px) {
        .logo {
          font-size: 5.25rem;
        }
      }
    </style>
    
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="stylesheet" href="/styles/custom-code.css" />
    
    <!-- Restore visibility once CSS is loaded -->
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // Ensure fonts are loaded before showing content
        if (document.fonts && document.fonts.ready) {
          document.fonts.ready.then(() => {
            document.documentElement.style.visibility = 'visible';
            document.documentElement.classList.add('fonts-loaded');
          });
        } else {
          // Fallback for browsers that don't support document.fonts
          document.documentElement.style.visibility = 'visible';
        }
      });
    </script>
  </head>
  <body>
    <Header />
    <SiteNav />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  aside {
    background-color: #FFF3E6 !important;
    border-left: 4px solid #FF9A3C !important;
    padding: 1rem !important;
    padding-right: 3.5rem !important;
    margin: 1.5rem 0 !important;
    position: relative !important;
    font-family: 'Nightingale', Georgia, serif !important;
    font-size: 1rem !important;
    line-height: 1.5 !important;
    color: #5A3E2B !important;
    border-radius: 0 8px 8px 0 !important;
    box-shadow: 0 2px 8px rgba(255, 154, 60, 0.1) !important;
  }

  aside p {
    margin: 0.5rem 0 !important;
  }

  aside p:first-child {
    margin-top: 0 !important;
  }

  aside p:last-child {
    margin-bottom: 0 !important;
  }

  aside::after {
    content: "" !important;
    background-image: url('/images/fox.png') !important;
    background-size: contain !important;
    background-repeat: no-repeat !important;
    background-position: center !important;
    position: absolute !important;
    width: 40px !important;
    height: 40px !important;
    bottom: 0.5rem !important;
    right: 0.5rem !important;
    opacity: 0.85 !important;
  }
</style>

<style>
  .site-main {
    max-width: 700px;
    margin: 2rem auto;
    padding: 0 1rem;
    margin-bottom: 6rem;
  }
</style>

<style is:global>
  .home-article a {
    position: relative;
    color: #333;
    transition: color 0.25s ease-in-out;
    transform-style: preserve-3d;
    backface-visibility: hidden;
  }

  .home-article a::before {
    background: #ff9a3c;
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.25s ease-in-out;
    z-index: -1;
    will-change: transform;
  }

  .article-content a {
    text-decoration: underline;
  }

  .article-content a:hover {
    text-decoration: none;
  }

  .home-article a:hover::before {
    transform: scaleX(1);
    transform-origin: left;
  }
</style>
