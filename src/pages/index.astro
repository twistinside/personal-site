---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { formatLongDate } from '../utils/formatDate';
import { getArticleSlug } from '../utils/articleSlug';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latestFive = sorted.slice(0, 5);
---
<BaseLayout description="Latest writing on software, Swift, and more.">
  <div class="home-articles">
    {latestFive.map(async (article, index) => {
      const { Content } = await render(article);
      return (
        <article class="home-article">
          <header>
            <h2><a href={`/articles/${getArticleSlug(article)}`}>{article.data.title}</a></h2>
            <p class="article-date">{formatLongDate(article.data.date)}</p>
          </header>
          <div class="article-content">
            <Content />
          </div>
          {index < latestFive.length - 1 && <hr class="article-divider" />}
        </article>
      );
    })}
    {latestFive.length === 5 && (
      <div class="archive-continuation">
        <hr class="article-divider" />
        <p class="article-content">Visit the <a href="/archive">archive</a> to keep reading.</p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .home-articles {
    margin-top: 0;
  }
  
  .home-article {
    margin-bottom: 3rem;
  }
  
  .home-article:first-child {
    margin-top: 0;
  }
  
  .home-article h2 {
    margin-bottom: 0.5rem;
    margin-top: 0;
    font-size: 2rem;
  }
  
  .home-article h2 a {
    color: inherit;
    text-decoration: none;
  }
  
  .article-date {
    color: #666;
    margin: 0;
    font-size: 0.9rem;
  }
  
  .article-content {
    font-weight: 300;
    line-height: 1.6;
    font-size: 1.1rem;
  }
  
  .article-content a {
    text-decoration: underline;
  }
  
  .article-content a:hover {
    text-decoration: none;
  }
  
  .article-content p {
    margin-bottom: 1.5rem;
  }
  
  .article-divider {
    margin: 3rem 0;
    border: 0;
    border-top: 1px solid #eaeaea;
  }

  .archive-continuation {
    margin: 1rem 0 0;
  }

  .archive-continuation .article-divider {
    margin-bottom: 5rem;
  }

  .archive-continuation p {
    margin: 0;
    text-align: center;
  }
</style>
