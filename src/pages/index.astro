---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latestFive = sorted.slice(0, 5);

// Function to format date as "Month Day, Year"
function formatDate(date: Date) {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}
---
<BaseLayout>
  <div class="home-articles">
    {latestFive.map(async (article, index) => {
      const { Content } = await article.render();
      return (
        <article class="home-article">
          <header>
            <h2><a href={`/articles/${article.slug}`}>{article.data.title}</a></h2>
            <p class="article-date">{formatDate(article.data.date)}</p>
          </header>
          <div class="article-content">
            <Content />
          </div>
          {index < latestFive.length - 1 && <hr class="article-divider" />}
        </article>
      );
    })}
  </div>
</BaseLayout>

<style>
  .home-articles {
    margin-top: 0;
  }
  
  .home-article {
    margin-bottom: 3rem;
  }
  
  .home-article:first-child {
    margin-top: 0;
  }
  
  .home-article h2 {
    margin-bottom: 0.5rem;
    margin-top: 0;
    font-size: 2rem;
  }
  
  .home-article h2 a {
    color: inherit;
    text-decoration: none; /* Explicitly ensure no underline for article titles */
  }
  
  .article-date {
    color: #666;
    margin: 0;
    font-size: 0.9rem;
  }
  
  .article-content {
    font-weight: 300;
    line-height: 1.6;
    font-size: 1.1rem;
  }
  
  .article-content a {
    text-decoration: underline; /* Add underline for links in article content */
  }
  
  .article-content a:hover {
    text-decoration: none; /* Remove underline on hover */
  }
  
  .article-content p {
    margin-bottom: 1.5rem;
  }
  
  /* Fancy styling for aside tags */
  .article-content aside {
    background-color: #FFF3E6; /* Light orange background */
    border-left: 4px solid #FF9A3C; /* Deeper orange border */
    padding: 1.5rem;
    margin: 2rem 0;
    position: relative;
    font-family: 'Nightingale', Georgia, serif;
    font-size: 1.3rem;
    line-height: 1.4;
    color: #5A3E2B; /* Warm brown text color */
    border-radius: 0 8px 8px 0;
    box-shadow: 0 2px 8px rgba(255, 154, 60, 0.1);
  }

  .article-content aside p {
    margin-bottom: 0.8rem;
  }

  .article-content aside p:last-child {
    margin-bottom: 0;
  }
  
  .article-divider {
    margin: 3rem 0;
    border: 0;
    border-top: 1px solid #eaeaea;
  }
</style>
