---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatShortDate } from '../utils/formatDate';
import { getArticleSlug } from '../utils/articleSlug';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BaseLayout title="Archive | Twistinside" description="Browse all articles from newest to oldest.">
  <h1>Site Archive</h1>
  <p class="archive-intro">All the articles that have been published on this site, ordered from newest to oldest.</p>
  
  <ul class="archive-list">
    {sorted.map(article => (
      <li>
        <span class="archive-date">{formatShortDate(article.data.date)}</span>
        <div class="archive-entry">
          <a href={`/articles/${getArticleSlug(article)}`}>{article.data.title}</a>
          {article.data.description && <p class="archive-description">{article.data.description}</p>}
        </div>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.5rem;
  }
  
  .archive-intro {
    color: #666;
    margin-bottom: 2rem;
  }
  
  .archive-list {
    list-style: none;
    padding: 0;
  }
  
  .archive-list li {
    margin-bottom: 1rem;
    display: flex;
    align-items: baseline;
  }
  
  .archive-date {
    color: #666;
    min-width: 150px;
    font-size: 0.9rem;
  }
  
  .archive-list a {
    position: relative;
    color: #333;
    text-decoration: none;
    font-weight: normal;
    transform-style: preserve-3d;
    backface-visibility: hidden;
    transition: color 0.25s ease-in-out;
  }
  
  .archive-list a::before {
    background: #ff9a3c;
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.25s ease-in-out;
    z-index: -1;
    margin: 0;
    will-change: transform;
  }
  
  .archive-list a:hover {
    text-decoration: none;
    transform: translateZ(0);
  }
  
  .archive-list a:hover::before {
    transform: scaleX(1);
    transform-origin: left;
  }

  .archive-entry {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    align-items: flex-start;
  }

  .archive-description {
    margin: 0;
    color: #666;
    font-size: 0.95rem;
    line-height: 1.35;
  }
</style>
