---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const { slug } = Astro.params;
const articles = await getCollection('articles');
const post = articles.find((a) => a.slug === slug);

if (!post) {
  throw new Error(`Post not found for slug: ${slug}`);
}

const { Content } = await post.render();

// Function to format date as "Month Day, Year"
function formatDate(date) {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.slug },
  }));
}
---

<BaseLayout title={post.data.title}>
  <article class="blog-article">
    <h2>{post.data.title}</h2>
    <p class="article-date">{formatDate(post.data.date)}</p>
    <div class="article-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-article h2 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .article-date {
    color: #666;
    margin-bottom: 1rem;
  }

  .article-content {
    font-weight: 300;
    line-height: 1.6;
    font-size: 1.1rem;
  }

  .article-content p {
    margin-bottom: 1.5rem;
  }

  /* Fancy styling for aside tags */
  .article-content aside {
    background-color: #FFF3E6; /* Light orange background */
    border-left: 4px solid #FF9A3C; /* Deeper orange border */
    padding: 1.5rem;
    margin: 2rem 0;
    position: relative;
    font-family: 'Nightingale', Georgia, serif;
    font-size: 1.3rem;
    line-height: 1.4;
    color: #5A3E2B; /* Warm brown text color */
    border-radius: 0 8px 8px 0;
    box-shadow: 0 2px 8px rgba(255, 154, 60, 0.1);
  }

  .article-content aside p {
    margin-bottom: 0.8rem;
  }

  .article-content aside p:last-child {
    margin-bottom: 0;
  }

  .article-content aside::before {
    content: "✦"; /* Decorative element */
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    font-size: 1.2rem;
    color: #FF9A3C;
    opacity: 0.6;
  }

  .aside-note {
    background: #f7e5cc;
    border-left: 4px solid #d78f2b;
    padding: 1rem;
    margin: 2rem 0;
    position: relative;
  }

  .aside-note .fox-icon {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    height: 40px;
  }
</style>
