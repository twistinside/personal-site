{
  "actions" : {
    "build" : {
      "enabled" : true,
      "script" : "npm install && npm run build"
    },
    "clean" : {
      "enabled" : true,
      "script" : "rm -rf node_modules && rm package-lock.json && rm -rf dist"
    },
    "run" : {
      "enabled" : true,
      "script" : "npm install && npm run dev"
    }
  }
}
